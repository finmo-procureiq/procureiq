# ============================================================
# ProcureIQ Enterprise — Environment Variables
# Copy to .env.local — NEVER commit this file to git
# ============================================================

# ── Supabase (supabase.com → Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: NEXT_PUBLIC_APP_URL=https://your-app.render.com

# ── Google OAuth (set in Supabase Auth dashboard, not here)
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET go in Supabase Dashboard
# → Authentication → Providers → Google
# You do NOT need to set them here — Supabase handles the OAuth flow.

# ── Optional: restrict Google SSO to your domain
# Set this in app/auth/login/page.tsx: hd: 'yourcompany.com'
NEXT_PUBLIC_GOOGLE_WORKSPACE_DOMAIN=yourcompany.com

# ── Email (optional — for custom SMTP beyond Supabase's built-in)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourcompany.com
# SMTP_PASS=your_app_specific_password
# EMAIL_FROM_NAME=ProcureIQ

# ── Security
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_random_32_char_string
